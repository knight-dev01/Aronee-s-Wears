{
  "entities": {
    "product": {
      "title": "Product",
      "description": "Represents a wear item or fashion accessory in the store inventory.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the wear item."
        },
        "description": {
          "type": "string",
          "description": "Detailed product description."
        },
        "price": {
          "type": "number",
          "description": "Price of the product in Nigerian Naira (NGN)."
        },
        "images": {
          "type": "array",
          "description": "List of WebP/optimized image URLs for the product gallery."
        },
        "category": {
          "type": "string",
          "description": "Category ID this product belongs to."
        },
        "stock": {
          "type": "integer",
          "description": "Current quantity available in inventory."
        },
        "featured": {
          "type": "boolean",
          "description": "Whether the product should be highlighted on the home page."
        },
        "status": {
          "type": "string",
          "enum": ["active", "draft", "out_of_stock"],
          "description": "Product visibility status."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["name", "description", "price", "images", "category", "stock", "featured", "status", "createdAt", "updatedAt"]
    },
    "category": {
      "title": "Category",
      "description": "Represents a grouping of products (e.g., Sneakers, Heels).",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable name of the category."
        },
        "image": {
          "type": "string",
          "description": "Cover image URL for the category banner."
        },
        "productCount": {
          "type": "integer",
          "description": "Pre-calculated count of active products to optimize speed."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["name", "image", "productCount", "createdAt"]
    },
    "settings": {
      "title": "Settings",
      "description": "Global store and contact details, business hours, and social media links.",
      "type": "object",
      "properties": {
        "whatsappNumber": {
          "type": "string",
          "description": "WhatsApp contact number in active format (e.g., +234...)."
        },
        "contactAddress": {
          "type": "string",
          "description": "Physical storefront address in Lagos."
        },
        "contactEmail": {
          "type": "string",
          "description": "Official Gmail/contact address."
        },
        "instagramUrl": {
          "type": "string",
          "description": "Instagram link."
        },
        "facebookUrl": {
          "type": "string",
          "description": "Facebook link."
        },
        "businessHours": {
          "type": "string",
          "description": "Weekly business hours description."
        },
        "deliveryLagos": {
          "type": "string",
          "description": "Estimated delivery time for Lagos."
        },
        "deliveryOutside": {
          "type": "string",
          "description": "Estimated delivery time outside Lagos."
        }
      },
      "required": ["whatsappNumber", "contactAddress", "contactEmail", "instagramUrl", "facebookUrl", "businessHours", "deliveryLagos", "deliveryOutside"]
    },
    "reservation": {
      "title": "Stock Reservation",
      "description": "Temporary stock hold while WhatsApp chat is pending.",
      "type": "object",
      "properties": {
        "productId": {
          "type": "string"
        },
        "productName": {
          "type": "string"
        },
        "quantity": {
          "type": "integer"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "confirmed", "expired", "cancelled"]
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["productId", "productName", "quantity", "status", "expiresAt", "createdAt"]
    },
    "admin": {
      "title": "Admin",
      "description": "Internal record of users who are authorized store administrators.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "addedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email", "addedAt"]
    },
    "subscriber": {
      "title": "Subscriber",
      "description": "Users who have signed in and opted for email updates.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "joinedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email", "joinedAt"]
    },
    "welcomeEmail": {
      "title": "Welcome Email Queue",
      "description": "Represents queued first-time welcome email requests for verified accounts.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "sent", "failed"]
        },
        "template": {
          "type": "string"
        },
        "couponCode": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "email", "status", "template", "couponCode", "createdAt"]
    },
    "adminNotification": {
      "title": "Admin Notification Email",
      "description": "Represents queued admin notification emails triggered when users redirect to WhatsApp.",
      "type": "object",
      "properties": {
        "to": {
          "type": "string"
        },
        "subject": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "sent", "failed"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "userId": {
          "type": "string"
        },
        "userEmail": {
          "type": "string"
        }
      },
      "required": ["to", "subject", "body", "status", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "product",
      "description": "Wears products and accessories database."
    },
    "/categories/{categoryId}": {
      "schema": "category",
      "description": "Categories for fast sorting and mobile browsing."
    },
    "/settings/{settingsId}": {
      "schema": "settings",
      "description": "Global shop configuration, address, social media links."
    },
    "/admins/{adminId}": {
      "schema": "admin",
      "description": "Allowed administrator users for Dashboard access."
    },
    "/subscribers/{subscriberId}": {
      "schema": "subscriber",
      "description": "User email list for storefront updates and discounts."
    },
    "/reservations/{reservationId}": {
      "schema": "reservation",
      "description": "Temporary stock holds for WhatsApp orders."
    },
    "/welcomeEmails/{welcomeEmailId}": {
      "schema": "welcomeEmail",
      "description": "Queued welcome coupons and greeting emails."
    },
    "/adminNotifications/{notificationId}": {
      "schema": "adminNotification",
      "description": "Admin notification mail queue for tracking sales clicks."
    }
  }
}
